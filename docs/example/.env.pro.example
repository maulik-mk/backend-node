# --- PRODUCTION ENVIRONMENT EXAMPLE ---
# Use Azure Managed Identity for sensitive services.
# No secrets or keys should be stored in this file.

NODE_ENV=production
PORT=3000
APP_NAME="Production User API"

# Database (PostgreSQL)
DB_HOST=your-prod-db-host.postgres.database.azure.com
DB_PORT=5432
DB_USER=api_user
DB_PASSWORD=YOUR_STRONG_DATABASE_PASSWORD
DB_NAME=user_db

# Redis (Production Cache)
REDIS_URL=rediss://your-redis-cache.redis.cache.windows.net:6380

# Security (Generate unique hex strings: openssl rand -hex 32)
COOKIE_SECRET=YOUR_PROD_COOKIE_SECRET_HEX
RESET_TOKEN_SECRET=YOUR_PROD_RESET_TOKEN_SECRET_HEX
ENCRYPTION_DECRYPTION_SECRET=YOUR_PROD_ENCRYPTION_SECRET_HEX
ENCRYPTION_DECRYPTION_SALT=YOUR_PROD_ENCRYPTION_SALT_HEX

# Azure Identity (Endpoints only, no keys)
AZURE_COMM_ENDPOINT=https://your-resource.communication.azure.com
AZURE_EMAIL_SENDER="DoNotReply@yourdomain.com"
COSMOS_ENDPOINT=https://your-cosmos-db.documents.azure.com
AZURE_STORAGE_ACCOUNT_URL=https://yourstorageaccount.blob.core.windows.net
AZURE_STORAGE_CONTAINER_NAME_AVATAR=upa
AZURE_CLIENT_ID=your-user-assigned-identity-client-id

# Other
CORS_ORIGIN=https://app.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com
MACHINE_ID=1
IPINFO_TOKEN=YOUR_IPINFO_TOKEN
