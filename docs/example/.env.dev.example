# --- DEVELOPMENT ENVIRONMENT EXAMPLE ---
# Local development settings. Use keys/connection strings or Azure CLI login.

NODE_ENV=development
PORT=4000
APP_NAME="Dev User API"

# Database (Local or Dev DB)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=user_db_dev

# Redis (Local)
REDIS_URL=redis://localhost:6379

# Security (Development placeholders)
COOKIE_SECRET=dev_secret_only_for_local_testing_32_chars
RESET_TOKEN_SECRET=dev_reset_secret_only_for_local_testing
ENCRYPTION_DECRYPTION_SECRET=dev_encryption_secret_16_chars_at_least
ENCRYPTION_DECRYPTION_SALT=dev_salt_8_chars

# Azure Services (Can use connection strings or Identity with 'az login')
# Option A: Use Connection Strings (Traditional)
AZURE_COMM_CONNECTION_STRING=endpoint=https://...;accesskey=...
COSMOS_KEY=your_local_cosmos_emulator_key_or_dev_key
AZURE_STORAGE_ACCOUNT_URL=DefaultEndpointsProtocol=https;AccountName=...

# Option B: Use Managed Identity (Login via 'az login' first)
# AZURE_COMM_ENDPOINT=https://your-dev-resource.communication.azure.com
# COSMOS_ENDPOINT=https://your-dev-cosmos.documents.azure.com
# AZURE_STORAGE_ACCOUNT_URL=https://yourdevstorage.blob.core.windows.net

AZURE_EMAIL_SENDER="DoNotReply@dev.yourdomain.com"
AZURE_STORAGE_CONTAINER_NAME_AVATAR=upa_dev

# Other
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
MACHINE_ID=1
IPINFO_TOKEN=
